# Exa Search API -- powers /deep-research
# Free tier: 1000 searches/month. Get your key at https://exa.ai
EXA_API_KEY=

# Notification channels for notify.sh
# Only configure the channels you use. Leave the rest blank.

# Default channel (telegram, slack, or sms)
NOTIFY_DEFAULT_CHANNEL=telegram

# Telegram -- get from @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack -- create an incoming webhook at api.slack.com/apps
SLACK_WEBHOOK_URL=

# SMS via Twilio -- get from twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_TO=
